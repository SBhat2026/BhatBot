{
  "name": "bhatbot",
  "version": "1.0.0",
  "description": "Personal Jarvis-style desktop agent that reads CLAUDE.md as live context",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac dir",
    "build:dmg": "electron-builder --mac dmg"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@notionhq/client": "^2.3.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "express": "^5.2.1",
    "node-pty": "^1.1.0",
    "node-telegram-bot-api": "^0.67.0",
    "otpauth": "^9.5.1",
    "playwright": "^1.60.0",
    "three": "^0.184.0",
    "twilio": "^6.0.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "electron": "^30.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.siddhant.bhatbot",
    "productName": "Bhatbot",
    "asar": false,
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "**/*",
      "!dist/**",
      "!CHANGES.md",
      "!ADAPTIVE_LEARNING_PLAN.md",
      "!.git/**",
      "!**/*.map"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dir"
      ],
      "icon": "build/icon.png",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "identity": null,
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Bhatbot listens for voice commands and the wake word.",
        "NSAppleEventsUsageDescription": "Bhatbot controls apps (Spotify, System Events, window management) on your behalf.",
        "NSCameraUsageDescription": "Bhatbot can capture images for vision tasks when you ask.",
        "LSUIElement": false
      }
    }
  }
}
