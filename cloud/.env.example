# Copy to .env (local) or set as host env vars (Fly/Railway/VPS). NEVER commit real keys.
BHATBOT_TOKEN=            # same secret token the app uses (from ~/.bhatbot/config.json mcpToken)
ANTHROPIC_API_KEY=       # chat
ELEVENLABS_API_KEY=      # Jarvis voice out
ELEVENLABS_VOICE_ID=EzDG2x1uAnCqbzN9Q0wA   # "BhatBot Jarvis" clone
OPENAI_API_KEY=          # voice in (Whisper)
# Optional: the Mac's tunnel base URL, so desktop tools relay to the Mac when it's awake.
MAC_RELAY_URL=           # e.g. https://your-stable-tunnel.example.com
# Optional: shared Notion memory bank (same ids scripts/notion-setup.js wrote to config.notion.*).
# With these set, the phone recalls + persists to the SAME bank the Mac/agents use.
NOTION_TOKEN=            # integration secret (ntn_… / secret_…)
NOTION_MEMORY_DB=        # config.notion.memoryDbId
NOTION_DAILYLOG_DB=      # config.notion.dailyLogDbId (optional)
PORT=8790
TTS_SPEED=1.08
ANTHROPIC_MODEL=claude-haiku-4-5
# Durable conversation history dir (mount a volume here on Fly/Railway for true persistence).
DATA_DIR=./data
